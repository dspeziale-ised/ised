# Copia questo file in .env (mai committare .env: contiene segreti) e
# valorizza solo le variabili delle funzionalità che vuoi usare. Nessuna è
# obbligatoria per avviare l'app in Docker (docker-compose.yml carica .env
# se esiste, altrimenti parte comunque).

# --- Postgres (letti anche da docker-compose.yml per costruire DATABASE_URL) ---
POSTGRES_DB=ised
POSTGRES_USER=ised
POSTGRES_PASSWORD=cambia-questa-password

# --- Proxy nmap sull'host Windows (vedi docs/DOCKER.md) ---
NMAP_PROXY_URL=http://host.docker.internal:8765
NMAP_PROXY_TOKEN=

# --- Classificazione AI (almeno uno, opzionale: senza nessuno la classificazione fallisce con un errore chiaro) ---
GROQ_API_KEY=
GEMINI_API_KEY=
OLLAMA_API_KEY=

# --- CVE da NVD (opzionale: senza key, rate limit pubblico più basso) ---
NVD_API_KEY=

# --- Notifiche report PDF (opzionali) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=
GMAIL_TO=
